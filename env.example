# Coveo search token extracted from the `coveo-info` cookie after logging into
# https://community.workday.com. Expires roughly 2 hours after capture.
# Re-capture flow: see README -> ./bin/refresh-token.sh
COVEO_SEARCH_TOKEN=

# Coveo organization ID (stable across captures).
COVEO_ORG_ID=workdayproductionurv9exm0

# Coveo searchHub claim — must match the value baked into the search token.
COVEO_SEARCH_HUB=IPE_AEM
